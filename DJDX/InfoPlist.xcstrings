        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "撮影したリザルト画面を写真に保存します。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DJDX 會將拍攝的成績畫面儲存到「照片」。"
