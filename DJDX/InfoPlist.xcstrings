    "NSCameraUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DJDX uses the camera to capture your result screens during a session."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "セッション中にリザルト画面を撮影するためにカメラを使用します。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DJDX 會在遊玩過程中使用相機拍攝成績畫面。"
          }
        }
      }
    },
    "NSHealthShareUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DJDX reads your workout, heart rate, and active energy to summarize your play sessions."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プレーセッションをまとめるために、ワークアウト・心拍数・アクティブエネルギーを読み出します。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DJDX 會讀取你的體能訓練、心率與活動能量，以彙整你的遊玩記錄。"
          }
        }
      }
    },
    "NSHealthUpdateUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DJDX saves your play sessions as workouts in the Health app."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プレーセッションをワークアウトとしてヘルスケアに保存します。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DJDX 會將你的遊玩記錄以體能訓練形式儲存到「健康」App。"
          }
        }
      }
    },
    "NSPhotoLibraryAddUsageDescription" : {
      "extractionState" : "manual",
